# NestJS API base URL (no trailing slash, no /api prefix)
VITE_API_BASE_URL=http://localhost:3000

# Use mock services instead of HTTP
# Set to false to connect to the real NestJS backend
VITE_USE_MOCK_API=false

# Auto-login in dev (seed user from supplement-back)
VITE_DEV_EMAIL=admin@tradutto.com
VITE_DEV_PASSWORD=password123
